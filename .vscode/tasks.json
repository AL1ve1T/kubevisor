{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Backend",
            "type": "shell",
            "command": "mvn spring-boot:run",
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "group": "kubetopo",
                "panel": "dedicated",
                "reveal": "always"
            }
        },
        {
            "label": "Run Frontend",
            "type": "shell",
            "command": "npm install && npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "group": "kubetopo",
                "panel": "dedicated",
                "reveal": "always"
            }
        },
        {
            "label": "Frontend Dev Server (debug)",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "isBackground": true,
            "presentation": {
                "group": "kubetopo",
                "panel": "dedicated",
                "reveal": "always"
            },
            "problemMatcher": {
                "owner": "vite",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*VITE.*",
                    "endsPattern": ".*Local:.*"
                }
            }
        },
        {
            "label": "Run All",
            "dependsOn": [
                "Run Backend",
                "Run Frontend"
            ],
            "dependsOrder": "parallel",
            "problemMatcher": []
        }
    ]
}
